# BRAIN 3.0 — Production Environment Variables
# Copy to .env and set a strong password before deploying:
#   cp .env.production.example .env

# PostgreSQL
POSTGRES_USER=brain3
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=brain3
POSTGRES_HOST=db
POSTGRES_PORT=5432

# API
API_HOST=0.0.0.0
API_PORT=8000

# CORS — comma-separated list of allowed origins (set to your TrueNAS IP/hostname)
CORS_ORIGINS=http://TRUENAS_IP:8000

# Backup
BACKUP_PATH=/mnt/pool/backups/brain3
BACKUP_RETENTION_DAYS=30
